<h1><%= @place.name %></h1>

<ul style="list-style: none; padding: 0;">
  <% @place.entries.each do |entry| %>
    <li>
      <strong><%= entry.title %></strong>
      <p><%= entry.occurred_on %></p>
      <p><%= entry.description %></p>
    </li>
  <% end %>
</ul>

<a href="/entries/new?place_id=<%= @place.id %>">New Post</a>